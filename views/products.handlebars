<h1>Productos</h1>

<div class="products-container">
{{#each products}}
    <div class="products">

        <img src='{{this.thumbnail}}' alt="thumbnail">
        <h2>{{this.title}}</h2>
        <p>{{this.description}}</p>
        <p>{{this.price}}</p>
        <button class="add-to-cart" data-id="{{this._id}}">Agregar al carrito</button>

        </div>
    {{/each}}
</div>

<div id="pagination">
    {{#if hasPrevPage}}
    <a href="/products?page={{prevPage}}">Anterior</a>
    {{/if}}

    {{#if hasNextPage}}
    <a href="/products?page={{nextPage}}">Siguiente</a>
    {{/if}}
    <span>Pagina {{page}}</span>
</div>

<script src="/js/products.js"></script>