<h1>Productos</h1>

<div class="products-cointainer">
{{#each products}}
    <div class="products">
        <p>{{this.title}}</p>
        <p>{{this.description}}</p>
        <p>{{this.price}}</p>
        <p>{{this.stock}}</p>
        <p>{{this.category}}</p>
        <p>{{this.thumbnail}}</p>
    </div>
</div>
{{/each}}

<div id="pagination">
    {{#if hasPrevPage}}
    <a href="/products?page={{prevPage}}">Anterior</a>
    {{/if}}

    {{#if hasNextPage}}
    <a href="/products?page={{nextPage}}">Siguiente</a>
    {{/if}}
    <span>Pagina {{page}}</span>
</div>